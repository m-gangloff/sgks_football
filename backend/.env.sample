# Football Statistics App Environment Variables
# Copy this file to .env and fill in your actual passwords

# Global password for accessing the app (shared with team members)
GLOBAL_PASSWORD=

# Admin password for editing capabilities (keep private)
ADMIN_PASSWORD=

# Database connection (optional). Unset = local SQLite file (backend/football.db).
# For Postgres (e.g. a Neon dev branch), use the psycopg driver:
# FOOTBALL_DB_URL=postgresql+psycopg://USER:PASSWORD@HOST/DBNAME?sslmode=require